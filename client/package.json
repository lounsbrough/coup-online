{
  "name": "coup-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "colord": "^2.9.3",
    "emoji-picker-react": "^4.18.0",
    "eslint": "^10.2.0",
    "firebase": "^12.12.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.1",
    "socket.io-client": "^4.8.3",
    "swr": "^2.4.1",
    "typescript": "^6.0.2",
    "web-vitals": "^5.2.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build-shared": "pnpm --prefix ../shared build",
    "start": "pnpm build-shared && vite",
    "start:cypress": "VITE_DISABLE_TRANSITIONS=true pnpm start",
    "build": "pnpm build-shared && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "pnpm build-shared && tsc --noEmit",
    "test": "pnpm build-shared && vitest run",
    "test:watch": "pnpm build-shared && vitest"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@shared": "link:../shared",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/chance": "^1.1.7",
    "@vitejs/plugin-react": "^6.0.1",
    "chance": "^1.1.13",
    "cypress": "^15.14.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
