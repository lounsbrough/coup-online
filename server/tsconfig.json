{
  "compilerOptions": {
    "module": "nodenext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2022",
    "noImplicitAny": true,
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "..",
    "strictNullChecks": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true
  },
  "include": ["./**/*", "../shared/types/game.ts"],
  "exclude": ["**/*.spec.ts", "node_modules"]
}
