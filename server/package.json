{
  "name": "coup-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@10.33.0",
  "pre-commit": [
    "ts.check",
    "build",
    "add-build"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run --coverage",
    "build": "rm -rf dist && tsc",
    "dev": "node --env-file-if-exists=.env.local -r ts-node/register index.ts",
    "start": "node dist/server/index.js",
    "migrate:valkey": "node -r ts-node/register src/utilities/migrateValkey.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.7.0",
    "glin-profanity": "^3.3.0",
    "joi": "^18.1.2",
    "@valkey/valkey-glide": "^2.3.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/body-parser": "^1.19.6",
    "@types/chance": "^1.1.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "chance": "^1.1.13",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "pre-commit": "^1.2.2",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
